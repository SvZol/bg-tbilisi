# === База данных ===
POSTGRES_USER=admin
POSTGRES_PASSWORD=замени_на_сложный_пароль
POSTGRES_DB=eventdb

# === JWT ===
SECRET_KEY=замени_на_длинную_случайную_строку_минимум_32_символа
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# === CORS — через запятую список разрешённых доменов ===
CORS_ORIGINS=https://твой-домен.com,https://www.твой-домен.com

# === URL фронтенда (используется в ссылках в письмах) ===
FRONTEND_URL=https://твой-домен.com

# === URL API для фронтенда (используется при сборке Docker) ===
NEXT_PUBLIC_API_URL=https://твой-домен.com/api

# === Email (SMTP) ===
# Gmail: включи "Двухфакторную аутентификацию" и создай "Пароль приложения"
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=твой@gmail.com
SMTP_PASS=пароль_приложения_gmail
FROM_EMAIL=твой@gmail.com
FROM_NAME=Бегущий город Тбилиси
